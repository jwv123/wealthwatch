{
  "buildCommand": "npm run build",
  "outputDirectory": "test/frontend/dist/wealthwatch/browser",
  "installCommand": "npm install && cd test/backend && npm install && cd ../frontend && npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}